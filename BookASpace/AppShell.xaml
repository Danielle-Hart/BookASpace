<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BookASpace.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BookASpace.Views"
    FlyoutBehavior="Disabled"
    Title="Book A' Space UC">

    <TabBar>
        <ShellContent
            Route="home"
            Title="Home"
            ContentTemplate="{DataTemplate views:HomePage}" />

        <ShellContent
            Route="rooms"
            Title="Rooms"
            ContentTemplate="{DataTemplate views:AvailableRoomsPage}" />

        <ShellContent
            Route="bookings"
            Title="Bookings"
            ContentTemplate="{DataTemplate views:MyReservationsPage}" />

        <ShellContent
            Route="account"
            Title="Account"
            ContentTemplate="{DataTemplate views:ProfilePage}" />
    </TabBar>
</Shell>
