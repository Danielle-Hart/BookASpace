<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookASpace.Views.RoomDetailsPage"
             Title="Room Details">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label x:Name="RoomNameLabel"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label x:Name="DescriptionLabel"
                   FontSize="16" />

            <Label x:Name="CapacityLabel"
                   FontSize="16" />

            <Label x:Name="WhiteboardLabel"
                   FontSize="16" />

            <Label x:Name="OutletsLabel"
                   FontSize="16" />

            <Button Text="Book Room"
                    Clicked="OnRoomClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>