<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookASpace.Views.HomePage"
             Title="Home">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Book A' Space UC"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               SemanticProperties.HeadingLevel="Level1" />

        <Label Text="Reserve Campus-Wide Study Rooms Quickly and Easily!"
               FontSize="16"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />

        <Button Text="View Available Rooms"
                Clicked="OnAvailableRoomsClicked" />

        <Button Text="My Reservations"
                Clicked="OnMyReservationsClicked" />
    </VerticalStackLayout>
</ContentPage>