<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BookASpace.Views.HomePage"
             Title="Home">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Book A' Space UC"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               SemanticProperties.HeadingLevel="Level1" />

        <Label Text="Campus study room reservation"
               FontSize="14"
               FontAttributes="Italic"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center" />

        <Label Text="Find available study rooms and book them in seconds."
               FontSize="16"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               TextColor="{AppThemeBinding Light=#333333, Dark=#DDDDDD}" />

        <Button Text="View Available Rooms"
                SemanticProperties.Description="Browse study rooms and filters"
                Clicked="OnAvailableRoomsClicked" />

        <Button Text="My Reservations"
                SemanticProperties.Description="View edit or cancel bookings"
                Clicked="OnMyReservationsClicked" />

        <Button Text="UC Account"
                SemanticProperties.Description="Open account profile page"
                Clicked="OnAccountClicked" />
    </VerticalStackLayout>
</ContentPage>
