<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BookASpace.ViewModels"
             xmlns:models="clr-namespace:BookASpace.Models"
             x:Class="BookASpace.Views.AvailableRoomsPage"
             x:DataType="vm:AvailableRoomsViewModel"
             Title="Available Rooms">

    <Grid Padding="20" RowDefinitions="Auto,*" RowSpacing="12">
        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Label Text="Filter:"
                   FontSize="18"
                   FontAttributes="Bold" />
            
            <Label Text="Filter rooms by building and amenities."
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}" />

            <Label Text="Building" FontAttributes="Bold" />
            <Picker Title="Building"
                    ItemsSource="{Binding Buildings}"
                    SelectedItem="{Binding SelectedBuilding, Mode=TwoWay}" />

            <HorizontalStackLayout Spacing="24">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Whiteboard" FontAttributes="Bold" />
                    <Switch IsToggled="{Binding RequireWhiteboard, Mode=TwoWay}" />
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Outlets" FontAttributes="Bold" />
                    <Switch IsToggled="{Binding RequireOutlets, Mode=TwoWay}" />
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Available Rooms" FontAttributes="Bold" />
                    <Switch IsToggled="{Binding RequireOutlets, Mode=TwoWay}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding FilteredRooms}"
                        Margin="0,8,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Room">
                    <Frame BorderColor="LightGray"
                           CornerRadius="10"
                           Padding="12"
                           Margin="0,5">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding DisplayName}"
                                   FontSize="20"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Description}" />

                            <Label Text="{Binding Capacity, StringFormat='Capacity: {0}'}" />

                            <Label Text="{Binding WhiteboardSummary}" />
                            <Label Text="{Binding OutletsSummary}" />

                            <Button Text="View details"
                                    Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.ViewDetailsCommand}"
                                    CommandParameter="{Binding .}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No rooms match these filters. Try clearing filters or picking another building."
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       Margin="0,40,0,0" />
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
